{
    "name": "mahmoud-mhamed/laravel-backup-station",
    "description": "Automatic database backup station for Laravel — schedule, retention, monthly keep-rules, rename and download backups from a beautiful dashboard.",
    "keywords": ["laravel", "backup", "database", "mysqldump", "schedule", "retention", "dashboard"],
    "license": "MIT",
    "type": "library",
    "require": {
        "php": "^8.1",
        "illuminate/support": "^10.0|^11.0|^12.0|^13.0",
        "illuminate/console": "^10.0|^11.0|^12.0|^13.0",
        "illuminate/database": "^10.0|^11.0|^12.0|^13.0",
        "symfony/process": "^6.0|^7.0"
    },
    "require-dev": {
        "orchestra/testbench": "^8.0|^9.0|^10.0|^11.0",
        "phpunit/phpunit": "^10.0|^11.0"
    },
    "autoload": {
        "psr-4": {
            "MahmoudMhamed\\BackupStation\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "MahmoudMhamed\\BackupStation\\Tests\\": "tests/"
        }
    },
    "extra": {
        "laravel": {
            "providers": [
                "MahmoudMhamed\\BackupStation\\BackupStationServiceProvider"
            ],
            "aliases": {
                "BackupStation": "MahmoudMhamed\\BackupStation\\Facades\\BackupStation"
            }
        }
    },
    "minimum-stability": "dev",
    "prefer-stable": true
}
